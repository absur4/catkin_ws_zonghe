<launch>
  <!-- Phone webcam via /dev/video* -->
  <arg name="video_device" default="/dev/video1"/>
  <arg name="image_width" default="1280"/>
  <arg name="image_height" default="720"/>
  <arg name="pixel_format" default="mjpeg"/>
  <arg name="camera_name" default="phone_camera"/>
  <arg name="frame_id" default="phone_camera_frame"/>

  <!-- Publish camera images -->
  <node pkg="usb_cam" type="usb_cam_node" name="usb_cam" output="screen">
    <param name="video_device" value="$(arg video_device)"/>
    <param name="image_width" value="$(arg image_width)"/>
    <param name="image_height" value="$(arg image_height)"/>
    <param name="pixel_format" value="$(arg pixel_format)"/>
    <param name="camera_name" value="$(arg camera_name)"/>
    <param name="frame_id" value="$(arg frame_id)"/>
    <!-- Remap to a common color image topic -->
    <remap from="image_raw" to="/camera/color/image_raw"/>
    <remap from="camera_info" to="/camera/color/camera_info"/>
  </node>

  <!-- Simple image viewer window -->
  <node pkg="image_view" type="image_view" name="phone_cam_view" output="screen">
    <remap from="image" to="/camera/color/image_raw"/>
  </node>
</launch>
