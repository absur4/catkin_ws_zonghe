<launch>
  <arg name="use_image_view" default="true"/>

  <!-- 真实导航（DWA） -->
  <include file="$(find robocup_navigation)/launch/navigation_dwa_3_14.launch"/>

  <!-- pick_place_run_vision 参数 -->
  <!-- 视觉参数：文件顶层包含 pick_place_run_vision:，需加载到全局命名空间 -->
  <rosparam file="$(find robocup_executive)/config/pick_place_vision_3_15_new.yaml" command="load"/>
  <!-- 任务参数：加载到 pick_place_run_vision 命名空间 -->
  <rosparam file="$(find robocup_executive)/config/task_config.yaml" command="load" ns="pick_place_run_vision"/>

  <!-- 视觉检测可视化：订阅相机，发布带框图像 -->
<!--   <node pkg="robocup_perception" type="vision_bbox_viewer_3_15_new.py" name="vision_bbox_viewer" output="screen">
    <rosparam file="$(find robocup_executive)/config/pick_place_vision_3_15_new.yaml" command="load"/>
    <param name="rgb_topic" value="/camera/color/image_raw"/>
    <param name="depth_topic" value="/camera/depth/image_rect_raw"/>
    <param name="annotated_topic" value="/vision/annotated_image_3_15_new"/>
    <param name="detection_rate_hz" value="1.0"/>
  </node> -->

  <!-- 可选：直接弹窗显示（需要 image_view 包） -->
  <node if="$(arg use_image_view)" pkg="image_view" type="image_view" name="vision_bbox_view" output="screen" required="false">
    <remap from="image" to="/vision/annotated_image_3_15_new"/>
  </node>

  <!-- 将相机 TF 挂到机械臂 link6（手眼标定外参，已从 camera->link6 取逆得到 link6->camera） -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="link6_to_camera_link"
        args="-0.0059991 0.12761867 0.03528631 0.09512232 -0.07523263 0.7016308 0.70214387 link6 camera_link" />
</launch>
